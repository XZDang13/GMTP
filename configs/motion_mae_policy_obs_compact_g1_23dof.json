{
  "data": {
    "motion_files": [
      "../mocap_data/G1_23dof_npz"
    ],
    "adapter_name": "stageii_npz",
    "past_frames": 8,
    "future_frames": 4,
    "split_mode": "by_motion",
    "val_ratio": 0.25,
    "batch_size": 128,
    "num_workers": 0,
    "pin_memory": true,
    "seed": 0
  },
  "feature": {
    "anchor_body_name": "pelvis",
    "end_effector_body_names": [
      "left_ankle_roll_link",
      "right_ankle_roll_link",
      "left_rubber_hand",
      "right_rubber_hand"
    ],
    "reference_feature_names": [
      "root",
      "joint"
    ],
    "target_feature_names": [
      "root",
      "joint"
    ],
    "policy_feature_names": [
      "root",
      "joint"
    ],
    "gravity_vector": [
      0.0,
      0.0,
      -1.0
    ]
  },
  "model": {
    "d_model": 192,
    "latent_dim": 48,
    "encoder_layers": 3,
    "decoder_layers": 2,
    "nhead": 4,
    "dim_feedforward": 384,
    "dropout": 0.1,
    "activation": "gelu"
  },
  "loss": {
    "reconstruction_loss": "mse",
    "slice_weights": {
      "root": 1.0,
      "joint": 1.0
    }
  },
  "optimizer": {
    "lr": 0.0002,
    "weight_decay": 0.01
  },
  "training": {
    "epochs": 80,
    "device": "auto",
    "grad_clip_norm": 1.0,
    "log_interval": 9999
  },
  "export": {
    "save_optimizer_state": true
  },
  "output_root": "runs",
  "run_name": "motion_mae_policy_obs_compact_g1_23dof"
}
