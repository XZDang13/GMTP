{
  "data": {
    "motion_files": [
      "env/assests/61_10_stageii.npz"
    ],
    "past_frames": 8,
    "future_frames": 4,
    "split_mode": "by_window",
    "val_ratio": 0.2,
    "batch_size": 256,
    "num_workers": 0,
    "pin_memory": true,
    "seed": 0
  },
  "feature": {
    "anchor_body_name": "pelvis",
    "end_effector_body_names": [
      "left_ankle_roll_link",
      "right_ankle_roll_link",
      "left_rubber_hand",
      "right_rubber_hand"
    ],
    "reference_feature_names": [
      "root",
      "joint",
      "end_effector"
    ],
    "target_feature_names": [
      "root",
      "joint",
      "end_effector"
    ],
    "policy_feature_names": [
      "root",
      "joint"
    ]
  },
  "model": {
    "latent_dim": 32,
