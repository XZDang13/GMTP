{
  "command": "pretrain motion-mae",
  "config": {
    "data": {
      "adapter_name": "stageii_npz",
      "batch_size": 128,
      "future_frames": 4,
      "max_train_windows": null,
      "max_val_windows": null,
      "motion_files": [
        "../mocap_data/G1_23dof_npz"
      ],
      "num_workers": 0,
      "past_frames": 8,
      "pin_memory": true,
      "seed": 0,
      "split_mode": "by_motion",
      "val_ratio": 0.25
    },
    "export": {
      "save_optimizer_state": true
    },
    "feature": {
      "anchor_body_name": "pelvis",
      "end_effector_body_names": [
        "left_ankle_roll_link",
        "right_ankle_roll_link",
        "left_rubber_hand",
        "right_rubber_hand"
      ],
      "gravity_vector": [
        0.0,
        0.0,
        -1.0
      ],
      "policy_feature_names": [
        "root",
        "joint"
      ],
      "reference_feature_names": [
        "root",
        "joint"
      ],
      "target_feature_names": [
        "root",
        "joint"
      ]
    },
    "loss": {
      "reconstruction_loss": "mse",
      "slice_weights": {
        "end_effector": 1.0,
        "joint": 1.0,
        "root": 1.0
      }
    },
    "model": {
      "activation": "gelu",
      "d_model": 192,
      "decoder_layers": 2,
      "dim_feedforward": 384,
      "dropout": 0.1,
      "encoder_layers": 3,
      "latent_dim": 48,
      "nhead": 4
    },
    "optimizer": {
      "lr": 0.0002,
      "weight_decay": 0.01
    },
    "output_root": "runs",
    "run_name": "motion_mae_policy_obs_compact_g1_23dof",
    "training": {
      "device": "auto",
      "epochs": 80,
      "grad_clip_norm": 1.0,
      "log_interval": 9999
    }
  }
}